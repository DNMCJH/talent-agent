# LLM (DeepSeek default; also works with OpenAI, any OpenAI-compatible provider)
LLM_API_KEY=sk-...
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# Embeddings (BGE local, no API needed)
EMBED_MODEL=BAAI/bge-m3
EMBED_DEVICE=cpu

# Qdrant (multi-tenant via payload.user_id filter)
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_PROJECTS=projects
QDRANT_COLLECTION_JDS=jds

# Postgres
POSTGRES_DSN=postgresql+asyncpg://talent:talent@postgres:5432/talent

# Redis
REDIS_URL=redis://redis:6379/0

# GitHub OAuth — register an OAuth App at https://github.com/settings/developers
# Callback URL (dev): http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# API
API_CORS_ORIGINS=["http://localhost:3000"]
API_SECRET=change-me-to-a-long-random-string
