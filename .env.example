# Copy to `.env` and fill in. This single file feeds both docker-compose
# (variable substitution + backend env_file) and local development.

# ---------------------------------------------------------------------------
# LLM (DeepSeek default; also works with OpenAI or any OpenAI-compatible API)
# ---------------------------------------------------------------------------
LLM_API_KEY=sk-...
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# ---------------------------------------------------------------------------
# Embeddings (BGE local model, no API needed).
# IMPORTANT: must match the model baked into the backend image. Changing this
# changes the vector dimension (bge-small-zh-v1.5 = 512, bge-m3 = 1024) and an
# existing Qdrant collection built with a different dimension will reject upserts.
# ---------------------------------------------------------------------------
EMBED_MODEL=BAAI/bge-small-zh-v1.5
EMBED_DEVICE=cpu

# ---------------------------------------------------------------------------
# Qdrant (multi-tenant via payload.user_id filter)
# ---------------------------------------------------------------------------
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_PROJECTS=projects
QDRANT_COLLECTION_JDS=jds

# ---------------------------------------------------------------------------
# Postgres. POSTGRES_PASSWORD is referenced by docker-compose for both the
# postgres service and the backend DSN — keep them consistent.
# ---------------------------------------------------------------------------
POSTGRES_PASSWORD=talent
POSTGRES_DSN=postgresql+asyncpg://talent:talent@postgres:5432/talent

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# ---------------------------------------------------------------------------
# GitHub OAuth — register an OAuth App at https://github.com/settings/developers
# Callback URL (dev): http://localhost:3000/api/auth/callback/github
# GITHUB_CLIENT_ID/SECRET are read by the backend; AUTH_GITHUB_ID/SECRET are the
# same values consumed by the NextAuth frontend — set all four.
# ---------------------------------------------------------------------------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_TOKEN=

# ---------------------------------------------------------------------------
# API
# API_SECRET signs session JWTs — MUST be a long random string in production.
# API_PUBLIC_BASE is the public frontend origin used to build email links;
# if unset, verification/reset links point at localhost.
# ---------------------------------------------------------------------------
API_CORS_ORIGINS=["http://localhost:3000"]
API_SECRET=change-me-to-a-long-random-string
API_PUBLIC_BASE=http://localhost:3000

# ---------------------------------------------------------------------------
# Email (Resend). Leave RESEND_API_KEY empty to disable email sending —
# registration still works, users are marked unverified but allowed in.
# ---------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM=Talent Agent <onboarding@resend.dev>

# ---------------------------------------------------------------------------
# Frontend (NextAuth). AUTH_SECRET signs NextAuth session cookies.
# ---------------------------------------------------------------------------
AUTH_SECRET=change-me-to-a-long-random-string
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ---------------------------------------------------------------------------
# Public domain (production). Caddy obtains a Let's Encrypt cert for this host
# and terminates TLS. Before deploying you must:
#   1. Point a DNS A record for this domain at the server's public IP.
#   2. Set the GitHub OAuth App callback URL to
#      https://<APP_DOMAIN>/api/auth/callback/github
#   3. Open ports 80 and 443 on the server firewall.
# ---------------------------------------------------------------------------
APP_DOMAIN=talent.projfit.top
