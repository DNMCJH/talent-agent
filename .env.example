# LLM (DeepSeek default; also works with OpenAI, any OpenAI-compatible provider)
LLM_API_KEY=sk-...
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# Embeddings (BGE local, no API needed; override to use API embeddings if desired)
EMBED_MODEL=BAAI/bge-m3
EMBED_DEVICE=cpu

# Qdrant (leave QDRANT_URL empty to use local file mode — no Docker needed)
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_LOCAL_PATH=./data/qdrant_storage
QDRANT_COLLECTION_PROJECTS=projects
QDRANT_COLLECTION_JDS=jds

# Project indexer
PROJECTS_ROOT=a:/VScode/Code/Projects
INDEX_EXCLUDE=["talent-agent",".git","node_modules",".venv"]

# State store (LangGraph checkpointer)
STATE_DB=./data/state.sqlite

# Streamlit
STREAMLIT_SERVER_PORT=8501
